<Container version="2">
  <Name>Assetto Corsa EVO Server</Name>
  <Repository>vaandal/acevo</Repository>
  <Registry>https://hub.docker.com/r/vaandal/acevo</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>

  <Overview>
Run Assetto Corsa EVO Dedicated Server in Docker using Wine.

IMPORTANT:
You must download server files via Steam (Tools → Assetto Corsa EVO Dedicated Server)
and copy them into /config/server.

Then paste your server config (Copy Command from launcher) into:
/config/server_args.txt
  </Overview>

  <Category>GameServers:</Category>

  <WebUI></WebUI>

  <Config Name="Config Path" Target="/config" Default="/mnt/user/appdata/assettocorsaevo" Mode="rw" Type="Path" />

  <Config Name="TCP Port" Target="9700" Default="9700" Mode="tcp" Type="Port" />
  <Config Name="UDP Port" Target="9700" Default="9700" Mode="udp" Type="Port" />

  <Config Name="Server Args (optional)" Target="SERVER_ARGS" Default="" Type="Variable" Description="Optional if using server_args.txt file" />

  <Config Name="PUID" Target="PUID" Default="99" Type="Variable" />
  <Config Name="PGID" Target="PGID" Default="100" Type="Variable" />
  <Config Name="TZ" Target="TZ" Default="Europe/Zagreb" Type="Variable" />
</Container>
