<?xml version="1.0"?>
<Container version="2">
  <Name>lynxprompt</Name>
  <Repository>drumsergio/lynxprompt:latest</Repository>
  <Registry>https://hub.docker.com/r/drumsergio/lynxprompt</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/GeiserX/LynxPrompt/issues</Support>
  <Project>https://github.com/GeiserX/LynxPrompt</Project>
  <Overview>Self-hostable AI configuration management platform for teams and individuals. Supports 30+ AI coding assistants (Cursor, Claude Code, GitHub Copilot, Windsurf, etc.) with a blueprint marketplace, interactive config wizard, and multi-provider authentication.&#xD;
[br][br]&#xD;
[b]Requires PostgreSQL.[/b] The docker-compose includes PostgreSQL, but you can point to an external instance via DATABASE_URL.&#xD;
[br][br]&#xD;
More info: https://github.com/GeiserX/LynxPrompt</Overview>
  <Category>Productivity: Tools:Development</Category>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/selfhosters/unRAID-CA-templates/master/templates/lynxprompt.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/selfhosters/unRAID-CA-templates/master/templates/img/lynxprompt.png</Icon>
  <ExtraSearchTerms>ai config prompt cursor claude copilot coding assistant llm</ExtraSearchTerms>
  <Requires>PostgreSQL database</Requires>
  <Config Name="Web UI Port" Target="3000" Default="3000" Mode="tcp" Description="LynxPrompt web interface port" Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Uploads" Target="/data/uploads" Default="/mnt/user/appdata/lynxprompt/uploads" Mode="rw" Description="User-uploaded blueprints and configuration files" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Database URL" Target="DATABASE_URL" Default="postgresql://lynxprompt:password@postgres:5432/lynxprompt" Mode="" Description="PostgreSQL connection string" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="NextAuth Secret" Target="NEXTAUTH_SECRET" Default="" Mode="" Description="Session encryption key (generate a random string)" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="App URL" Target="APP_URL" Default="http://localhost:3000" Mode="" Description="Base URL of this instance" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Enable AI" Target="ENABLE_AI" Default="false" Mode="" Description="Enable AI-powered features (requires ANTHROPIC_API_KEY)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Anthropic API Key" Target="ANTHROPIC_API_KEY" Default="" Mode="" Description="Anthropic API key (required when ENABLE_AI=true)" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Enable Registration" Target="ENABLE_USER_REGISTRATION" Default="true" Mode="" Description="Allow public user registration" Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>
